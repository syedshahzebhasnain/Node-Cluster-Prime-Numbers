{
  "name": "node-cluster-prime-numbers",
  "version": "2.0.0",
  "description": "Blazing-fast prime number engine using worker_threads, segmented sieve, and native crypto",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "benchmark": "node index.js --benchmark --end 10000000",
    "benchmark:big": "node index.js --benchmark --end 100000000",
    "benchmark:nohash": "node index.js --no-hash --end 100000000",
    "demo": "node index.js --end 1000000 --stdout | head -20"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["prime", "sieve", "worker_threads", "performance", "math"],
