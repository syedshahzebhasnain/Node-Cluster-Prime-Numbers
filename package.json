{
  "name": "node-cluster-prime-numbers",
  "version": "4.0.0",
  "description": "Blazing-fast prime engine + quantum-inspired Mersenne hunter. Segmented sieve, worker_threads, NTT-exact Lucas-Lehmer, entanglement oracle, p-bit annealing.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "node --test test/sieve.test.js && node --test test/worker.test.js",
    "test:sieve": "node --test test/sieve.test.js",
    "test:worker": "node --test test/worker.test.js",
    "benchmark": "node index.js --benchmark --end 10000000",
    "hunt": "node mersenne-hunt.js --start 2 --end 10000",
    "hunt:benchmark": "node mersenne-hunt.js --benchmark",
    "hunt:verify": "node mersenne-hunt.js --verify 127",
    "hunt:serve": "node mersenne-hunt.js --serve --port 3000",
    "demo": "node index.js --end 1000 --stdout",
    "quantum-hunt": "node quantum-hunt.js",
    "quantum:verify": "node quantum-hunt.js --ntt-verify",
    "quantum:oracle": "node quantum-hunt.js --oracle-test",
    "quantum:benchmark": "node quantum-hunt.js --benchmark",
    "quantum:hunt": "node quantum-hunt.js --start 2 --end 10000"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mersenne-primes",
    "lucas-lehmer",
    "prime-numbers",
    "sieve-of-eratosthenes",
    "worker-threads",
    "distributed-computing",
    "miller-rabin",
    "bigint",
    "performance",
    "mathematics",
    "cryptography",
    "parallel-computing"
  ],
  "author": "syedshahzebhasnain",
  "license": "MIT"
}